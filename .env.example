APP_NAME="Mundo Asiático API"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=America/Santiago
APP_URL=https://api.mundoasiatico.cl

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_CL

# Frontend URL para CORS (Vercel)
FRONTEND_URL=https://mundoasiatico.cl

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ─── Base de Datos ──────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=mundoasiatico_db
DB_USERNAME=mundoasiatico_user
DB_PASSWORD=

# ─── Sesiones y Caché ────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.mundoasiatico.cl

CACHE_STORE=file
QUEUE_CONNECTION=database

# ─── Email Transaccional ─────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mail.mundoasiatico.cl
MAIL_PORT=465
MAIL_USERNAME=pedidos@mundoasiatico.cl
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="pedidos@mundoasiatico.cl"
MAIL_FROM_NAME="Mundo Asiático"

# ─── Transbank Webpay Plus ───────────────────────────────────────────────────
# AMBIENTE: integration | production
TRANSBANK_ENV=integration
TRANSBANK_COMMERCE_CODE=597055555532
TRANSBANK_API_KEY=579B532A7440BB0C9079DED94D31EA1615BACEB56610332264630D42D0A36B1C

# ─── Sanctum (CORS para API) ─────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=mundoasiatico.cl,localhost,localhost:3000
